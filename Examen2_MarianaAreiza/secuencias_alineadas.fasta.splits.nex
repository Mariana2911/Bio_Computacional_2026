#nexus

BEGIN Taxa;
DIMENSIONS ntax=5;
TAXLABELS
[1] 'Actinomycetota_bacterium'
[2] 'Mycobacteriaceae_bacterium'
[3] 'Mycobacterium_simiae'
[4] 'Mycolicibacterium_hassiacum'
[5] 'Mycobacteroides_salmoniphilum'
;
END; [Taxa]

BEGIN Splits;
DIMENSIONS ntax=5 nsplits=15;
FORMAT labels=no weights=yes confidences=no intervals=no;
MATRIX
	100	 2,
	100	 4,
	6	 2 4,
	100	 3,
	100	 5,
	7	 3 5,
	100	 1,
	90	 2 5,
	34	 3 4,
	32	 1 3,
	29	 1 4,
	2	 1 2,
	1	 1 5,
	0	 4 5,
	0	 2 3,
;
END; [Splits]

